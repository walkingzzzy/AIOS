{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aios/provider-descriptor.schema.json",
  "title": "AIOS Provider Descriptor",
  "type": "object",
  "required": ["provider_id", "version", "kind", "capabilities", "execution_location"],
  "properties": {
    "provider_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string" },
    "owner": { "type": "string" },
    "worker_contract": { "type": "string" },
    "result_protocol_schema_ref": { "type": "string" },
    "trust_policy_modes": { "type": "array", "items": { "type": "string" } },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["capability_id"],
            "properties": {
              "capability_id": { "type": "string", "minLength": 1 },
              "read_only": { "type": "boolean" },
              "recoverable": { "type": "boolean" },
              "approval_required": { "type": "boolean" },
              "external_side_effect": { "type": "boolean" },
              "dynamic_code": { "type": "boolean" },
              "user_interaction_required": { "type": "boolean" },
              "supported_targets": { "type": "array", "items": { "type": "string" } },
              "input_schema_refs": { "type": "array", "items": { "type": "string" } },
              "output_schema_refs": { "type": "array", "items": { "type": "string" } },
              "audit_tags": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "execution_location": { "enum": ["local", "sandbox", "attested_remote"] },
    "sandbox_class": { "type": "string" },
    "required_permissions": { "type": "array", "items": { "type": "string" } },
    "resource_budget": {
      "type": "object",
      "properties": {
        "max_memory_mb": { "type": "integer", "minimum": 1 },
        "max_cpu_percent": { "type": "integer", "minimum": 1 },
        "max_concurrency": { "type": "integer", "minimum": 1 },
        "max_requests_per_minute": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "supported_targets": { "type": "array", "items": { "type": "string" } },
    "input_schema_refs": { "type": "array", "items": { "type": "string" } },
    "output_schema_refs": { "type": "array", "items": { "type": "string" } },
    "timeout_policy": { "type": "string" },
    "retry_policy": { "type": "string" },
    "healthcheck": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "endpoint": { "type": "string" },
        "interval_seconds": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "audit_tags": { "type": "array", "items": { "type": "string" } },
    "taint_behavior": { "type": "string" },
    "degradation_policy": { "type": "string" },
    "compat_permission_manifest": {
      "$ref": "aios/compat-permission-manifest.schema.json"
    },
    "remote_registration": {
      "type": "object",
      "properties": {
        "source_provider_id": { "type": "string" },
        "provider_ref": { "type": "string" },
        "endpoint": { "type": "string" },
        "auth_mode": { "type": "string" },
        "auth_header_name": { "type": "string" },
        "auth_secret_env": { "type": "string" },
        "target_hash": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "registered_at": { "type": "string" },
        "display_name": { "type": "string" },
        "control_plane_provider_id": { "type": "string" },
        "registration_status": { "type": "string" },
        "last_heartbeat_at": { "type": "string" },
        "heartbeat_ttl_seconds": { "type": "integer" },
        "revoked_at": { "type": "string" },
        "revocation_reason": { "type": "string" },
        "attestation": {
          "type": "object",
          "properties": {
            "mode": { "type": "string" },
            "issuer": { "type": "string" },
            "subject": { "type": "string" },
            "issued_at": { "type": "string" },
            "expires_at": { "type": "string" },
            "evidence_ref": { "type": "string" },
            "digest": { "type": "string" },
            "status": { "type": "string" }
          },
          "additionalProperties": true
        },
        "governance": {
          "type": "object",
          "properties": {
            "fleet_id": { "type": "string" },
            "governance_group": { "type": "string" },
            "policy_group": { "type": "string" },
            "registered_by": { "type": "string" },
            "approval_ref": { "type": "string" },
            "allow_lateral_movement": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
