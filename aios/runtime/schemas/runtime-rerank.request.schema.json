{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aios/runtime-rerank.request.schema.json",
  "title": "AIOS Runtime Rerank Request",
  "type": "object",
  "required": ["session_id", "task_id", "query", "documents"],
  "properties": {
    "session_id": { "type": "string" },
    "task_id": { "type": "string" },
    "query": { "type": "string" },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "top_k": { "type": "integer", "minimum": 1 },
    "model": { "type": "string" },
    "preferred_backend": { "type": "string" },
    "execution_token": { "type": "object" }
  },
  "additionalProperties": true
}
