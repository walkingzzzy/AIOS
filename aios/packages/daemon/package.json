{
    "name": "@aios/daemon",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "bin": {
        "aios-daemon": "./dist/index.js"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@aios/shared": "workspace:*",
        "@anthropic-ai/sdk": "^0.32.0",
        "@google/generative-ai": "^0.21.0",
        "@larksuiteoapi/node-sdk": "^1.56.1",
        "@modelcontextprotocol/sdk": "^1.25.2",
        "@types/jsonwebtoken": "^9.0.10",
        "better-sqlite3": "^11.0.0",
        "brightness": "^3.0.0",
        "jsonwebtoken": "^9.0.3",
        "loudness": "^0.4.2",
        "mathjs": "^15.1.0",
        "node-notifier": "^10.0.1",
        "node-schedule": "^2.1.1",
        "open": "^10.1.0",
        "openai": "^4.67.0",
        "p-queue": "^9.1.0",
        "playwright": "^1.40.0",
        "ps-list": "^8.1.1",
        "psl": "^1.15.0",
        "say": "^0.16.0",
        "systeminformation": "^5.23.0",
        "wallpaper": "^7.2.1",
        "ws": "^8.16.0",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.11",
        "@types/node": "^20.11.0",
        "@types/node-notifier": "^8.0.5",
        "@types/node-schedule": "^2.1.8",
        "@types/psl": "^1.1.3",
        "@types/ws": "^8.5.10",
        "tsup": "^8.0.2",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "vitest": "^1.6.0"
    }
}
