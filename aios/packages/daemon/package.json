{
    "name": "@aios/daemon",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "bin": {
        "aios-daemon": "./dist/index.js"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts",
        "dev": "tsx watch src/index.ts",
