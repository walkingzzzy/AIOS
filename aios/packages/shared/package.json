{
    "name": "@aios/shared",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "typescript": "^5.3.3",
        "tsup": "^8.0.2"
    }
}