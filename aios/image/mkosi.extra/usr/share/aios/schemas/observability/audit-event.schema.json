{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aios/audit-event.schema.json",
  "title": "AIOS Audit Event",
  "type": "object",
  "required": ["audit_id", "timestamp", "user_id", "session_id", "task_id", "capability_id", "decision"],
  "properties": {
    "schema_version": { "type": "string" },
    "audit_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "generated_at": { "type": "string", "format": "date-time" },
    "user_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "approval_id": { "type": "string" },
    "provider_id": { "type": "string" },
    "capability_id": { "type": "string", "minLength": 1 },
    "decision": {
      "type": "string",
      "enum": [
        "allowed",
        "denied",
        "approved",
        "rejected",
        "revoked",
        "dry-run",
        "needs-approval",
        "token-issued",
        "token-valid",
        "token-consumed",
        "token-invalid",
        "token-reused",
        "approval-scope-mismatch",
        "approval-pending",
        "approval-approved",
        "approval-rejected",
        "approval-revoked"
      ]
    },
    "execution_location": { "enum": ["local", "sandbox", "attested_remote"] },
    "route_state": { "type": "string" },
    "update_id": { "type": "string" },
    "boot_id": { "type": "string" },
    "image_id": { "type": "string" },
    "artifact_path": { "type": "string" },
    "taint_summary": { "type": "string" },
    "result": { "type": ["object", "string", "null"] },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
