{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aios/audit-evidence-report.schema.json",
  "title": "AIOS Audit Evidence Report",
  "type": "object",
  "required": [
    "report_id",
    "generated_at",
    "workspace",
    "session",
    "json_report",
    "markdown_report",
    "inputs",
    "audit_store",
    "summary",
    "domain_evidence",
    "approval_scopes",
    "approval_scope_mismatches",
    "tasks",
    "notes"
  ],
  "properties": {
    "report_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "workspace": { "type": "string" },
    "json_report": { "type": "string" },
    "markdown_report": { "type": "string" },
    "session": {
      "type": "object",
      "required": ["session_id", "user_id", "status", "created_at"],
      "properties": {
        "session_id": { "type": "string" },
        "user_id": { "type": "string" },
        "status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "last_resumed_at": { "type": ["string", "null"], "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": true
    },
    "inputs": {
      "type": "object",
      "required": [
        "session_db",
        "policy_audit_log",
        "audit_index",
        "runtime_events_log",
        "remote_audit_log",
        "observability_log",
        "domain_config"
      ],
      "properties": {
        "session_db": { "type": ["string", "null"] },
        "policy_audit_log": { "type": ["string", "null"] },
        "audit_index": { "type": ["string", "null"] },
        "runtime_events_log": { "type": ["string", "null"] },
        "remote_audit_log": { "type": ["string", "null"] },
        "observability_log": { "type": ["string", "null"] },
        "domain_config": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "audit_store": {
      "type": "object",
      "required": [
        "active_segment_path",
        "active_record_count",
        "archived_segment_count",
        "archived_segments"
      ],
      "properties": {
        "active_segment_path": { "type": ["string", "null"] },
        "active_record_count": { "type": "integer", "minimum": 0 },
        "archived_segment_count": { "type": "integer", "minimum": 0 },
        "archived_segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "record_count"],
            "properties": {
              "path": { "type": "string" },
              "record_count": { "type": "integer", "minimum": 0 },
              "first_timestamp": { "type": ["string", "null"], "format": "date-time" },
              "last_timestamp": { "type": ["string", "null"], "format": "date-time" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "task_count",
        "audit_entry_count",
        "runtime_event_count",
        "remote_audit_count",
        "observability_record_count",
        "approval_ref_count",
        "approval_scope_count",
        "target_bound_approval_count",
        "constraint_bound_approval_count",
        "approval_scope_mismatch_count",
        "archived_segment_count",
        "domain_count",
        "covered_domains",
        "audit_decisions",
        "runtime_event_kinds",
        "observability_kinds",
        "artifact_paths"
      ],
      "properties": {
        "task_count": { "type": "integer", "minimum": 0 },
        "audit_entry_count": { "type": "integer", "minimum": 0 },
        "runtime_event_count": { "type": "integer", "minimum": 0 },
        "remote_audit_count": { "type": "integer", "minimum": 0 },
        "observability_record_count": { "type": "integer", "minimum": 0 },
        "approval_ref_count": { "type": "integer", "minimum": 0 },
        "approval_scope_count": { "type": "integer", "minimum": 0 },
        "target_bound_approval_count": { "type": "integer", "minimum": 0 },
        "constraint_bound_approval_count": { "type": "integer", "minimum": 0 },
        "approval_scope_mismatch_count": { "type": "integer", "minimum": 0 },
        "archived_segment_count": { "type": "integer", "minimum": 0 },
        "domain_count": { "type": "integer", "minimum": 0 },
        "covered_domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "audit_decisions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "runtime_event_kinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observability_kinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifact_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "domain_evidence": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "domain",
          "source_count",
          "record_count",
          "artifact_paths",
          "audit_decisions",
          "event_kinds",
          "status_values",
          "provider_ids",
          "approval_refs",
          "capability_ids",
          "action_ids",
          "sources",
          "notes"
        ],
        "properties": {
          "domain": { "type": "string" },
          "source_count": { "type": "integer", "minimum": 0 },
          "record_count": { "type": "integer", "minimum": 0 },
          "task_count": { "type": "integer", "minimum": 0 },
          "artifact_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "audit_decisions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "event_kinds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status_values": {
            "type": "array",
            "items": { "type": "string" }
          },
          "provider_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "approval_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "capability_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "action_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "format", "path", "present", "record_count"],
              "properties": {
                "kind": { "type": "string" },
                "format": { "type": "string" },
                "path": { "type": "string" },
                "present": { "type": "boolean" },
                "record_count": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": true
            }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "approval_scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "approval_ref",
          "constraints",
          "decisions",
          "mismatch_count",
          "scope_mismatches"
        ],
        "properties": {
          "approval_ref": { "type": "string" },
          "session_id": { "type": ["string", "null"] },
          "task_id": { "type": ["string", "null"] },
          "capability_id": { "type": ["string", "null"] },
          "approval_lane": { "type": ["string", "null"] },
          "execution_location": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "target_hash": { "type": ["string", "null"] },
          "constraints": { "type": "object" },
          "decisions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "mismatch_count": { "type": "integer", "minimum": 0 },
          "scope_mismatches": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["approval_ref", "scope_mismatch"],
              "properties": {
                "approval_ref": { "type": "string" },
                "task_id": { "type": ["string", "null"] },
                "capability_id": { "type": ["string", "null"] },
                "timestamp": { "type": ["string", "null"], "format": "date-time" },
                "reason": { "type": ["string", "null"] },
                "scope_mismatch": { "type": "object" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "approval_scope_mismatches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["approval_ref", "scope_mismatch"],
        "properties": {
          "approval_ref": { "type": "string" },
          "task_id": { "type": ["string", "null"] },
          "capability_id": { "type": ["string", "null"] },
          "timestamp": { "type": ["string", "null"], "format": "date-time" },
          "reason": { "type": ["string", "null"] },
          "scope_mismatch": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "state",
          "audit_decisions",
          "runtime_event_kinds",
          "remote_audit_statuses",
          "observability_kinds",
          "approval_refs",
          "approval_scopes",
          "provider_ids",
          "artifact_paths"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "state": { "type": "string" },
          "title": { "type": ["string", "null"] },
          "audit_decisions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "runtime_event_kinds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "remote_audit_statuses": {
            "type": "array",
            "items": { "type": "string" }
          },
          "observability_kinds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "approval_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "approval_scopes": {
            "type": "array",
            "items": { "type": "object" }
          },
          "provider_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "artifact_paths": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "audit_entries": {
      "type": "array",
      "items": { "type": "object" }
    },
    "runtime_events": {
      "type": "array",
      "items": { "type": "object" }
    },
    "remote_audits": {
      "type": "array",
      "items": { "type": "object" }
    },
    "observability_records": {
      "type": "array",
      "items": { "type": "object" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
