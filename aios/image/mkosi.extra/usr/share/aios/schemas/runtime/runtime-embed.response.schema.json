{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aios/runtime-embed.response.schema.json",
  "title": "AIOS Runtime Embed Response",
  "type": "object",
  "required": ["backend_id", "route_state", "vector_dimension", "embeddings", "degraded", "rejected"],
  "properties": {
    "backend_id": { "type": "string" },
    "route_state": { "type": "string" },
    "vector_dimension": { "type": "integer", "minimum": 1 },
    "embeddings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["input_index", "vector"],
        "properties": {
          "input_index": { "type": "integer", "minimum": 0 },
          "vector": {
            "type": "array",
            "items": { "type": "number" }
          },
          "text_length": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "degraded": { "type": "boolean" },
    "rejected": { "type": "boolean" },
    "reason": { "type": "string" },
    "provider_id": { "type": "string" },
    "runtime_service_id": { "type": "string" },
    "provider_status": { "type": "string" },
    "queue_saturated": { "type": "boolean" },
    "runtime_budget": { "type": "object" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
